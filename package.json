{
  "name": "@tdreyno/he-said",
  "version": "0.11.1",
  "description": "Functional auth rules for JavaScript and TypeScript applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdreyno/he-said.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./she-said": {
      "types": "./dist/she-said.d.ts",
      "default": "./dist/she-said.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "default": "./dist/rbac/index.js"
    },
    "./abac": {
      "types": "./dist/abac/index.d.ts",
      "default": "./dist/abac/index.js"
    },
    "./acl": {
      "types": "./dist/acl/index.d.ts",
      "default": "./dist/acl/index.js"
    },
    "./rebac": {
      "types": "./dist/rebac/index.d.ts",
      "default": "./dist/rebac/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.ts",
      "default": "./dist/drizzle/index.js"
    },
    "./mermaid": {
      "types": "./dist/mermaid/index.d.ts",
      "default": "./dist/mermaid/index.js"
    }
  },
  "bin": {
    "he-said-mermaid": "bin/he-said-mermaid.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postgres:test:up": "docker compose -f docker-compose.postgres.yml up -d",
    "postgres:test:down": "docker compose -f docker-compose.postgres.yml down --remove-orphans",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage",
    "test:ci:sonar": "jest --runInBand --coverage --testPathIgnorePatterns src/core/algebra-postgres.integration.test.ts",
    "coverage:sonar": "node scripts/prepare-sonar-coverage.mjs",
    "sonar": "if [ -f ./.env ]; then set -a && . ./.env && set +a; fi && npm run test:ci:sonar && npm run coverage:sonar && npx sonar-scanner",
    "sonar:quality-gate": "if [ -f ./.env ]; then set -a && . ./.env && set +a; fi && node scripts/sonar-quality-gate.mjs",
    "test:postgres": "jest --runInBand src/core/algebra-postgres.integration.test.ts",
    "test:postgres:ci": "npm run postgres:test:up && npm run test:postgres; npm run postgres:test:down",
    "test:types": "tsc -p tsconfig.types.json --noEmit",
    "release": "npm run build && changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@types/jest": "^29.5.13",
    "@types/pg": "^8.15.5",
    "eslint": "^9.39.1",
    "drizzle-orm": "^0.44.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.6",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "sonar-scanner": "^3.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.44.2"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
